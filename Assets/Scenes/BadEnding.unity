--- !u!114 &8062400042491899724
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4010180757107110991}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: deb7d23cb5e125441a39e41a4052bbfe, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  monologueList:
  - "\uADF8\uB798, \uB4DC\uB514\uC5B4 \uBAA8\uB4E0 \uAC8C \uAE30\uC5B5\uB0AC\uC5B4.\n\uBD88\uAE38\uC774
    \uCE58\uC19F\uB358 \uADF8 \uBC24... \uCC28\uAC00\uC6B4 \uAE08\uC18D\uC73C\uB85C
    \uAC00\uB4DD\uD588\uB358 \uC2E4\uD5D8\uC2E4\uC740\n\uC21C\uC2DD\uAC04\uC5D0 \uB728\uAC70\uC6B4
    \uBB34\uB364\uC774 \uB410\uC5B4."
  - "\uC218\uC11D \uC5F0\uAD6C\uC6D0\uC774\uB77C\uB294 \uAC70\uCC3D\uD55C \uC774\uB984\uD45C\uB3C4,\n\uC5F0\uAD6C
    \uC131\uACFC\uB3C4 \uBD89\uC740 \uD654\uC5FC \uC18D\uC5D0\uC120 \uC544\uBB34
    \uC758\uBBF8\uAC00 \uC5C6\uC5C8\uC9C0.\n\uADF8\uB798\uC11C \uB098\uB294 \uC774
    \uD0C8\uCD9C\uAD6C \uC5C6\uB294 \uC5F0\uC625\uC774\uB77C\uB294 \uACF3\uC5D0 \uAC07\uD788\uAC8C
    \uB41C\uAC70\uC57C."
  - "\uD558\uC9C0\uB9CC \uC5F0\uC625\uC5D0\uC11C \uAC00\uC7A5 \uC794\uC778\uD588\uB358
    \uAC74,\n\uAE30\uC5B5\uC744 \uC783\uC740 \uCC44 \uB0B4\uAC00 \uC774\uACF3\uC5D0\uC11C
    \uCCA0\uC800\uD788 \uC81C 3\uC790\uAC00 \uB418\uC5B4\n\uB098 \uC790\uC2E0\uC744
    \uC9C0\uCF1C\uBCF4\uACE0 \uC788\uC5C8\uB2E4\uB294 \uC0AC\uC2E4\uC774\uC57C."
  - "\uBD88\uAE38\uC740 \uC544\uC9C1 \uAEBC\uC9C0\uC9C0 \uC54A\uC558\uC5B4.\n\uB098\uB294
    \uC5EC\uC804\uD788 \uADF8\uB0A0\uC758 \uD654\uC7AC \uC18D\uC5D0 \uAC07\uD600\n\uB098\uB97C
    \uC9C0\uCF1C\uBCF4\uBA70 \uC601\uC6D0\uD788 \uD0C0\uB4E4\uC5B4 \uAC00\uACE0 \uC788\uC744
    \uBFD0\uC774\uC57C."
  - "\uBC30\uB4DC \uC5D4\uB529\n\uC601\uC6D0\uD788 \uC5F0\uC625\uC5D0 \uAC07\uD78C
    \uC8FC\uC778\uACF5"
