--- !u!114 &8621782595633402202
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4900429833389139171}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 58a04dde953376c429d025e1c406b836, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  monologueList:
  - "\uADF8\uB798, \uB4DC\uB514\uC5B4 \uBAA8\uB4E0 \uAC8C \uAE30\uC5B5\uB0AC\uC5B4.\n\uBD88\uAE38\uC774
    \uCE58\uC19F\uB358 \uADF8 \uBC24... \uCC28\uAC00\uC6B4 \uAE08\uC18D\uC73C\uB85C
    \uAC00\uB4DD\uD588\uB358 \uC2E4\uD5D8\uC2E4\uC740\n\uC21C\uC2DD\uAC04\uC5D0 \uB728\uAC70\uC6B4
    \uBB34\uB364\uC774 \uB410\uC5B4."
  - "\uADF8\uB0A0\uC758 \uC2E4\uD5D8\uC2E4 \uD654\uC7AC\uB294 \uC815\uB9D0 \uC608\uACE0\uB3C4
    \uC5C6\uC774 \uCC3E\uC544\uC628 \uC0AC\uACE0\uC600\uC9C0.\n\uC5F0\uAD6C\uC6D0\uC73C\uB85C\uC11C
    \uC313\uC544\uC628 \uBA85\uC608\uAC00 \uC21C\uC2DD\uAC04\uC5D0 \uC7AC\uAC00 \uB418\uC5B4
    \uD769\uC5B4\uC9C0\uB358 \uC21C\uAC04,\n\uB0B4 \uC758\uC2DD\uB3C4 \uD568\uAED8
    \uB04A\uACA8\uBC84\uB9B0 \uC904 \uC54C\uC558\uB294\uB370..."
  - "\uADF8\uB3D9\uC548 \uB098\uB294 \uB300\uCCB4 \uC5B4\uB514\uC5D0 \uC788\uC5C8\uB358
    \uAC78\uAE4C?\n\uB9C8\uCE58 \uC720\uB839\uCC98\uB7FC, \uC81C3\uC790\uC758 \uB208\uC73C\uB85C
    \uB098 \uC790\uC2E0\uC758 \uBE44\uCC38\uD55C \uC0AC\uD22C\uB97C \n\uAC74\uB108\uD3B8\uC5D0\uC11C
    \uC9C0\uCF1C\uBD10\uC57C\uB9CC \uD588\uB358 \uC2DC\uAC04\uB4E4."
  - "\uD558\uC9C0\uB9CC \uC774\uC81C\uB294 \uC544\uB2C8\uC57C.\n\uC774\uC81C\uC57C
    \uBE44\uB85C\uC18C \uB0A8\uC758 \uC2DC\uC120\uC774 \uC544\uB2CC, \uB0B4 \uB208\uC73C\uB85C
    \uC138\uC0C1\uC744 \uBCF4\uACE0 \uC788\uC5B4.\n\uADF8\uB798... \uB09C \uC0B4\uC544\uB0A8\uC740
    \uAC70\uC57C."
  - "\uC9C4\uC5D4\uB529\n\uC8FD\uC74C\uC5D0\uC11C \uBC97\uC5B4\uB09C \uC8FC\uC778\uACF5"
