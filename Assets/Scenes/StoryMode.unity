    \uC57D\uD488 \uB0C4\uC0C8...\r\n\uB300\uCCB4 \uB0B4\uAC00 \uC65C \uC5EC\uAE30
    \uC788\uB294 \uAC70\uC9C0?"
  - "\uC774 \uBCF5\uB3C4... \uC5B4\uB518\uAC00 \uC775\uC219\uD574... \uCC98\uC74C
    \uC628 \uAC83 \uAC19\uC9C0 \uC54A\uC544.\r\n\uB9C8\uCE58 \uC608\uC804\uC5D0 \uBD24\uB358
    \uAC83 \uCC98\uB7FC \uC0DD\uC0DD\uD574.\r\n\uC5EC\uAE34... \uC5F0\uAD6C\uC18C\uC600\uC744\uAE4C?"
  - "\uC800\uAE30... \uAC78\uC5B4\uAC00\uB294 \uC800 \uC0AC\uB78C, \uB0AF\uC124\uC9C0\uAC00
    \uC54A\uC544.\r\n\uC6B0\uB9AC\uAC00... \uC5B4\uB514\uC11C \uB9CC\uB0AC\uC5C8\uC9C0?"
  - "\uB098\uB294 \uC774 \uACF3\uC5D0\uC11C \uC5B4\uB5A4 \uC874\uC7AC\uC600\uC744\uAE4C?\r\n\uC5F0\uAD6C\uC6D0?
    \uC544\uB2C8\uBA74... \uC2E4\uD5D8\uC758 \uCC38\uAC00\uC790?"
  - "\uD558\uC580 \uC637\uC744 \uC785\uC740 \uC0AC\uB78C\uB4E4\uC774 \uC720\uB9AC
    \uBCBD \uB108\uBA38\uB85C \uAC80\uC740 \uC637\uC744 \uC785\uC740 \uC0AC\uB78C\uB4E4\uC744
    \uCCD0\uB2E4\uBCF4\uACE0 \uC788\uC5B4...\r\n\uBB34\uC2A8 \uC77C\uC774 \uC77C\uC5B4\uB09C
    \uAC78\uAE4C?\r\n\uB098\uB294 \uADF8 \uAD11\uACBD\uC744 \uC5B4\uB514\uC11C \uC9C0\uCF1C\uBCF4\uACE0
    \uC788\uB358 \uAC70\uC9C0?"
  - "\uC5B4\uB514\uC120\uAC00 \uADDC\uCE59\uC801\uC778 \uAE30\uACC4\uC74C\uC774 \uB4E4\uB824\uC640.\r\n\uC2E4\uD5D8\uC774
    \uC2DC\uC791\uB418\uB294 \uC18C\uB9AC\uC77C\uAE4C?\r\n\uC544\uB2C8\uBA74, \uC8FD\uC5B4\uAC00\uB294
    \uB204\uAD70\uAC00\uB97C \uBD99\uC7A1\uAE30 \uC704\uD574 \uC0DD\uBA85 \uC720\uC9C0
    \uC7A5\uCE58\uAC00 \uB0B4\uB294 \uC18C\uB9AC\uC77C\uAE4C?"
  - "\uD76C\uBBF8\uD558\uAC8C \uB4E4\uB9AC\uB294 \uBAA9\uC18C\uB9AC\uB4E4... \uB204\uAD70\uAC00
    \uD750\uB290\uB07C\uACE0 \uC788\uC5B4.\r\n\uC808\uB9DD\uC5D0 \uBE60\uC9C4 \uD53C\uC2E4\uD5D8\uC790\uB4E4\uC758
    \uC808\uADDC\uC77C\uAE4C?\r\n\uC544\uB2C8\uBA74, \uAE30\uC801\uC744 \uBC14\uB77C\uB294
    \uAC00\uC871\uB4E4\uC758 \uAC04\uC808\uD568\uC77C\uAE4C?"
  - "\uC5B4\uB5A4 \uC5F0\uAD6C\uC6D0\uC774 \uB2E4\uB978 \uC0AC\uB78C\uC758 \uB208\uC744
    \uD53C\uD574 \uC9D9\uC740 \uC5B4\uB460 \uC18D\uC5D0 \uBB34\uC5B8\uAC00\uB97C
    \uAE4A\uC219\uD788 \uC228\uACA8\uB454\uAC78 \uBD24\uC5B4.\r\n\uB9CC\uC57D \uB0B4\uAC00
    \uC774 \uD1B5\uC81C\uB41C \uC21C\uD658\uC744 \uB04A\uC5B4\uB0B4\uC57C \uD558\uB294
    \uC2E4\uD5D8\uCCB4\uB77C\uBA74,\r\n\uAC10\uC2DC\uAC00 \uB2FF\uC9C0 \uC54A\uB294
    \uC800 \uC5B4\uB460\uB9CC\uC774 \uC720\uC77C\uD55C \uD0C8\uCD9C\uAD6C\uC77C\uAC70\uC57C."
  - "\uC61B\uB0A0\uC5D0 \uCC45\uC5D0\uC11C \uBD24\uB358 \uD55C \uAD6C\uC808\uC774
    \uAE30\uC5B5 \uC18D\uC5D0\uC11C \uB5A0\uC62C\uB77C.\r\n\uC0B6\uACFC \uC8FD\uC74C\uC758
    \uACBD\uACC4\uC5D0 \uAC07\uD78C \uC790\uAC00 \uD0C8\uCD9C\uD558\uB294 \uBC29\uBC95\uC740\r\n\uC800
    \uB208\uBD80\uC2E0 \uBE5B\uC744 \uD5A5\uD574 \uB098\uC544\uAC00\uB294 \uAC83\uBFD0\uC774\uB77C\uACE0."
  - "\uAE30\uC5B5\uC774 \uB04A\uAE30\uAE30 \uC9C1\uC804\uC758 \uAC10\uAC01...\r\n\uC544\uC8FC
    \uAC15\uD558\uACE0 \uD558\uC580 \uBE5B\uC774 \uC2DC\uC57C\uB97C \uC628\uD1B5
    \uB4A4\uB36E\uC5C8\uC5B4.\r\n\uB098\uB97C \uC9D1\uC5B4\uC0BC\uD0A8 \uAC70\uB300\uD55C
    \uD3ED\uBC1C...\uC774\uC5C8\uC744\uAE4C?"
  - "\uC9C0\uD558 0\uCE35?... \uC774\uB7F0 \uACF3\uC774 \uC2E4\uC7AC\uD560 \uB9AC
    \uC5C6\uC5B4!\r\n\uD655\uC2E4\uD55C \uAC74, \uC9C0\uAE08 \uB0B4\uAC00 \uB51B\uACE0
    \uC788\uB294 \uC774 \uB545\uC740 \uD604\uC2E4\uC774 \uC544\uB2C8\uB77C\uB294
    \uAC70\uC57C.\r\n\uC774\uC81C\uB294 \uC815\uD574\uC57C \uD574, \uC5B4\uB514\uB85C\uB4E0
    \uC774 \uACBD\uACC4\uC120\uC744 \uB118\uC5B4\uC57C\uB9CC \uD574."
  loopResetList:
  - "\uBB50\uC9C0... \uBD84\uBA85\uD788 \uC81C\uB300\uB85C \uC62C\uB77C\uC654\uB294\uB370?\n\uC65C
    \uB2E4\uC2DC 10\uCE35\uC778\uAC78\uAE4C?\n\uACF5\uAC04\uC774 \uB4A4\uD2C0\uB824
    \uC788\uC5B4."
  - "\uB610 \uC5EC\uAE30\uC57C, \uB0B4\uAC00 \uBB34\uC5B8\uAC00 \uB193\uCE58\uACE0
    \uC788\uC5B4.\n\uC544\uC8FC \uC0AC\uC18C\uD55C \uBB34\uC5B8\uAC00\uB97C..."
  - "\uC9C0\uACA8\uC6B4 \uACF5\uAC04... \uB9C8\uCE58 \uC774 \uCE35 \uC790\uCCB4\uAC00
    \uB098\uB97C \uBE44\uC6C3\uB294 \uAC83 \uAC19\uAD70.\r\n\uC774\uBC88\uC5D4 \uC808\uB300\uB85C
    \uC18D\uC9C0 \uC54A\uACA0\uC5B4!"
  playerMovement: {fileID: 0}
  mainMenuSceneName: MainMenu
